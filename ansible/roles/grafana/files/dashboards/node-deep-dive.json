{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["gonka"],
      "title": "Fleet Overview",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "Node Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "dark-red", "text": "UNKNOWN" } }, "type": "value" },
            { "options": { "1": { "color": "dark-green", "text": "INFERENCE" } }, "type": "value" },
            { "options": { "2": { "color": "dark-blue", "text": "POC" } }, "type": "value" },
            { "options": { "3": { "color": "dark-yellow", "text": "TRAINING" } }, "type": "value" },
            { "options": { "4": { "color": "dark-orange", "text": "STOPPED" } }, "type": "value" },
            { "options": { "5": { "color": "dark-red", "text": "FAILED" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "Current Status",
      "type": "stat",
      "targets": [
        {
          "expr": "gonka_node_status{instance=\"$instance\"}",
          "legendFormat": "{{ node_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "dark-red", "text": "UNKNOWN" } }, "type": "value" },
            { "options": { "1": { "color": "dark-green", "text": "INFERENCE" } }, "type": "value" },
            { "options": { "2": { "color": "dark-blue", "text": "POC" } }, "type": "value" },
            { "options": { "3": { "color": "dark-yellow", "text": "TRAINING" } }, "type": "value" },
            { "options": { "4": { "color": "dark-orange", "text": "STOPPED" } }, "type": "value" },
            { "options": { "5": { "color": "dark-red", "text": "FAILED" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "Intended Status",
      "type": "stat",
      "targets": [
        {
          "expr": "gonka_node_intended_status{instance=\"$instance\"}",
          "legendFormat": "{{ node_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "semi-dark-green", "text": "IDLE" } }, "type": "value" },
            { "options": { "1": { "color": "dark-blue", "text": "GENERATING" } }, "type": "value" },
            { "options": { "2": { "color": "dark-purple", "text": "VALIDATING" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "PoC Status",
      "type": "stat",
      "targets": [
        {
          "expr": "gonka_node_poc_current_status{instance=\"$instance\"}",
          "legendFormat": "{{ node_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "PoC Weight",
      "type": "stat",
      "targets": [
        {
          "expr": "gonka_node_poc_weight{instance=\"$instance\"}",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-red", "value": null },
              { "color": "dark-green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "color": "dark-red", "text": "NOT ASSIGNED" } }, "type": "value" },
            { "options": { "1": { "color": "dark-green", "text": "ASSIGNED" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "Timeslot Assigned",
      "type": "stat",
      "targets": [
        {
          "expr": "gonka_node_poc_timeslot_assigned{instance=\"$instance\"}",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "color": "green", "text": "SYNCED" } }, "type": "value" },
            { "options": { "1": { "color": "red", "text": "CATCHING UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "Sync Status",
      "type": "stat",
      "targets": [
        {
          "expr": "gonka_chain_catching_up{instance=\"$instance\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 201,
      "title": "Miss Rate & Inferences",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "count"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Inference Count vs Missed Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gonka_participant_inference_count{instance=\"$instance\"}",
          "legendFormat": "Inferences",
          "refId": "A"
        },
        {
          "expr": "gonka_participant_missed_requests{instance=\"$instance\"}",
          "legendFormat": "Missed",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Miss Rate %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gonka_participant_missed_requests{instance=\"$instance\"} / (gonka_participant_inference_count{instance=\"$instance\"} + gonka_participant_missed_requests{instance=\"$instance\"} + 1)",
          "legendFormat": "Miss Rate",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },

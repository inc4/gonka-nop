  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["gonka", "monitoring", "node"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
